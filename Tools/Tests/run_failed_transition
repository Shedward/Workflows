#!/usr/bin/env bash
set -euo pipefail

. "$(dirname "$0")/../Lib/request.sh"
. "$(dirname "$0")/../Lib/workflow.sh"

main() {
  start_workflow "FailingWorkflow"
  take_transition "GoNextStep"
  assert_state "shouldFail"

  # Take the failing transition — should return HTTP 500
  assert_fails try_take_transition "FailAction"

  # Instance should still be at shouldFail (state unchanged)
  assert_state "shouldFail"

  # transitionState should be failed (manual failures now persist failure state,
  # consistent with automatic transitions)
  assert_transition_failed

  # The failing transition should still be available (state didn't change)
  assert_transition_available "FailAction"

  # Retry the same transition — should fail again
  assert_fails try_take_transition "FailAction"
  assert_state "shouldFail"
  assert_transition_failed

  echo "Finished Successfully"
}

main "$@"
