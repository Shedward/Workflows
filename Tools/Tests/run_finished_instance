#!/usr/bin/env bash
set -euo pipefail

. "$(dirname "$0")/../Lib/request.sh"
. "$(dirname "$0")/../Lib/workflow.sh"

main() {
  local count_before
  count_before="$(instance_count)"

  # Run SimpleWorkflow to completion
  start_workflow "SimpleWorkflow"
  local finished_id="$INSTANCE_ID"

  # Verify count increased
  local count_during
  count_during="$(instance_count)"
  if [[ "$count_during" -ne $((count_before + 1)) ]]; then
    echo "Expected count $((count_before + 1)), got $count_during" >&2
    exit 1
  fi

  take_transition "StartA"
  take_transition "StartB"
  take_transition "Finalize"
  assert_finished "$finished_id"

  # Verify count restored
  local count_after
  count_after="$(instance_count)"
  if [[ "$count_after" -ne "$count_before" ]]; then
    echo "Expected count $count_before after finish, got $count_after" >&2
    exit 1
  fi

  # GET finished instance should return 410 Gone with the final instance body
  local raw
  raw="$(request_raw GET "/workflowInstances/$finished_id")"
  local status="${raw%%$'\n'*}"
  local body="${raw#*$'\n'}"
  if [[ "$status" != "410" ]]; then
    echo "Expected status 410 for finished instance, got $status" >&2
    exit 1
  fi
  local finished_at
  finished_at="$(jq -r '.finishedAt' <<<"$body")"
  if [[ "$finished_at" == "null" || -z "$finished_at" ]]; then
    echo "Expected finishedAt to be set in 410 body, got null" >&2
    exit 1
  fi

  # GET on a never-existing instance should still return 404
  local raw404
  raw404="$(request_raw GET "/workflowInstances/does-not-exist-$$")"
  local status404="${raw404%%$'\n'*}"
  if [[ "$status404" != "404" ]]; then
    echo "Expected status 404 for unknown instance, got $status404" >&2
    exit 1
  fi

  # POST takeTransition on finished instance should fail
  assert_fails request POST "/workflowInstances/$finished_id/takeTransition" \
    '{"transitionProcessId":"StartA"}'

  echo "Finished Successfully"
}

main "$@"
