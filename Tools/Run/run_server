#!/usr/bin/env bash
set -euo pipefail

WORKSPACE="$(dirname "$0")/../../Workflow.xcworkspace"
SCHEME="workflow-server"
DERIVED_DATA="$(dirname "$0")/../../.build/DerivedData"

echo "Building $SCHEME..."
xcodebuild build \
  -workspace "$WORKSPACE" \
  -scheme "$SCHEME" \
  -configuration Debug \
  -derivedDataPath "$DERIVED_DATA" \
  -quiet

EXECUTABLE="$DERIVED_DATA/Build/Products/Debug/$SCHEME"

if [[ ! -x "$EXECUTABLE" ]]; then
  echo "Build failed: executable not found at $EXECUTABLE" >&2
  exit 1
fi

echo "Starting server..."
exec "$EXECUTABLE"
